{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "mutate": ["src/curation/scoring.ts", "src/identity/dedup.ts"],
  "reporters": ["clear-text", "progress", "html"],
  "htmlReporter": {
    "fileName": "output/mutation/report.html"
  },
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  },
  "tempDirName": "output/stryker-tmp",
  "cleanTempDir": true
}
